# ------------------------------------------------------------------
# CuraTrax backend configuration
# Copy this file to ".env" and fill in the real values.
# NEVER commit the real .env to git.
# ------------------------------------------------------------------

# Port the server listens on (most hosts set this for you).
PORT=3000

# Which website origins may call this API (comma-separated), or "*" for any.
# In production, lock this to your real site:
ALLOWED_ORIGINS=https://curatrax.com,https://www.curatrax.com

# ---- SMTP (email sending) -----------------------------------------
# Defaults below are for ZOHO MAIL INDIA (your domains use mx.zoho.in).
# If your Zoho account is on the global data center instead, use smtp.zoho.com.
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_SECURE=true
# The mailbox you authenticate as. Must be a real Zoho mailbox.
SMTP_USER=info@stelliteworks.com
# A Zoho APP PASSWORD (not your normal login password). See README for steps.
SMTP_PASS=your-zoho-app-password-here

# ---- Email addressing ---------------------------------------------
# "From" must be the authenticated mailbox above (or a verified alias of it).
MAIL_FROM=CuraTrax <info@stelliteworks.com>
# Where lead notifications are delivered (comma-separated).
TEAM_TO=info@stelliteworks.com,support@curatrax.com
# Send an automatic confirmation email back to the person who submitted?
AUTOREPLY=true

# Brand name used in email subjects/headers.
BRAND_NAME=CuraTrax
